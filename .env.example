# ── Qdrant (reuse the agentMem0 instance in production) ──
QDRANT_INTERNAL_URL=http://qdrant:6333
# QDRANT_API_KEY=
WIKI_COLLECTION=wiki_knowledge

# ── Embeddings (OpenAI, text-embedding-3-small) ──
OPENAI_API_KEY=sk-...
WIKI_EMBED_MODEL=text-embedding-3-small
WIKI_EMBED_DIMS=1536

# ── Extractor LLM (Claude Haiku; OpenAI is the fallback) ──
ANTHROPIC_API_KEY=sk-ant-...
WIKI_EXTRACTOR_MODEL=claude-haiku-4-5-20251001
WIKI_OPENAI_EXTRACTOR_MODEL=gpt-4o-mini

# ── API auth ──
WIKI_AUTH_TOKEN=change-me-rest-token
WIKI_MCP_BEARER_TOKEN=change-me-mcp-token

# ── Behaviour ──
WIKI_MIN_CONFIDENCE=0.5
# REST rate limit: max requests / window (seconds) per token. 0 = disabled.
WIKI_RATE_LIMIT=120
WIKI_RATE_WINDOW=60
# Comma-separated keywords that block a message from reaching any LLM / storage.
WIKI_SKIP_KEYWORDS=password,mật khẩu,matkhau,token,secret,api key,apikey,private key,seed phrase,cvv,otp

# ── WhatsApp source (Phase 3) ──
# Cheap keep/skip classifier (Qwen 7B on DeepInfra); falls back to OpenAI if unset.
DEEPINFRA_API_KEY=
WHATSAPP_CLASSIFIER_MODEL=Qwen/Qwen2.5-7B-Instruct
# Contacts whose messages are never ingested (remoteJid / phone / name fragments).
WHATSAPP_CONTACT_BLACKLIST=

# ── RAG 2.0 reranker (Phase 4, optional — ?rerank=true) ──
COHERE_API_KEY=
RERANK_MODEL=rerank-english-v3.0

# ── Query telemetry ──
WIKI_QUERY_LOG_PATH=./data/query_log.jsonl

# ── Consolidation alerts (Phase 5, optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
